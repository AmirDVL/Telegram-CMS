# ── Compose / deployment tier ────────────────────────────────────────────────
# Active Docker Compose profiles, i.e. how much of the stack runs:
#   (empty)                                  → minimal  (core only, cloud Bot API)
#   largemedia                               → standard (core + local Bot API)
#   backoffice,largemedia                    → full     (core + web back-office; default)
# See docs/PROFILES.md. Edit this line and `docker compose up -d --remove-orphans`
# to change tier on a running host.
COMPOSE_PROFILES=backoffice,largemedia

# ── Telegram (userbot / MTProto) ─────────────────────────────────────────────
# From https://my.telegram.org → API development tools
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=changeme
TELEGRAM_SESSION_NAME=cms_userbot
# 2FA password for the dedicated userbot account (set if the account has one)
TELEGRAM_2FA_PASSWORD=
# Where the .session file + downloaded media live (container paths)
SESSION_DIR=/data/sessions
MEDIA_DIR=/media

# ── Bot API bot (aiogram) ───────────────────────────────────────────────────
BOT_TOKEN=123456:changeme
# Local telegram-bot-api server (bypasses the 50 MB cloud limit, ≤2 GB).
# Leave EMPTY to use Telegram's cloud API instead (50 MB upload cap) — this is
# what the `minimal` tier does (no botapi container). Keep MEDIA_MAX_SIZE_DEFAULT
# at 52428800 (50 MB) when this is empty so oversized media is omitted at ingest.
BOT_API_SERVER_URL=http://botapi:8081
BOT_API_SERVER_FILE_PATH=/var/lib/telegram-bot-api
# Destination (output) channel id and the private editor supergroup id
DESTINATION_CHANNEL_ID=-1000000000000
EDITOR_GROUP_ID=-1000000000001

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://cms:cms@postgres:5432/cms
POSTGRES_PASSWORD=cms

# ── Redis (ARQ queue + delayed jobs + dedupe cache) ─────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth (web back-office) ──────────────────────────────────────────────────
# REQUIRED: set to a long random string. The API refuses to start if this is
# empty or still the placeholder below.
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGO=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14
# Seed super-admin created on first boot of the api/cli
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# ── Policies / retention (defaults from plan §9) ───────────────────────────
DEDUPE_LOOKBACK_DAYS=7
AUDIT_RETENTION_DAYS=90
MEDIA_RETENTION_DAYS=30
MAX_CONCURRENT_PUBLISHES=1
PUBLISH_SPACING_SECONDS=2.0
MEDIA_MAX_SIZE_DEFAULT=2147483648

# ── Web / API ───────────────────────────────────────────────────────────────
API_BASE_URL=http://api:8000
WEB_BASE_URL=http://web:3000
# Comma-separated CORS origins for the API
CORS_ORIGINS=*

# ── Caddy / public domain ───────────────────────────────────────────────────
# The FQDN Caddy will serve the web back-office + api on (auto TLS)
APP_DOMAIN=cms.example.com

# ── AI Transformation ─────────────────────────────────────────────────────
# Global kill-switch: set to true to enable AI transforms on channels that opt in
AI_ENABLED=false
# OpenAI-compatible endpoint (works with OpenAI, Azure, Ollama, vLLM, OpenRouter)
AI_PROVIDER_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048
AI_TIMEOUT_SECONDS=30
